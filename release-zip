#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

CURRENT=$(node -p "require('./manifest.json').version")
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
NEW_VERSION="${MAJOR}.${MINOR}.$((PATCH + 1))"

echo "Bumping version: ${CURRENT} -> ${NEW_VERSION}"

sed -i "s/\"version\": \"${CURRENT}\"/\"version\": \"${NEW_VERSION}\"/" manifest.json
sed -i "s/\"version\": \"${CURRENT}\"/\"version\": \"${NEW_VERSION}\"/" package.json

echo "Running tests..."
if ! npm test; then
    echo "Tests failed. Reverting version."
    sed -i "s/\"version\": \"${NEW_VERSION}\"/\"version\": \"${CURRENT}\"/" manifest.json
    sed -i "s/\"version\": \"${NEW_VERSION}\"/\"version\": \"${CURRENT}\"/" package.json
    exit 1
fi

NAME="prequel-error-codes"
OUTPUT="${NAME}-${NEW_VERSION}.zip"

rm -f "${NAME}"-*.zip

zip -r "$OUTPUT" \
    manifest.json \
    background.js \
    content.js \
    styles.css \
    popup/ \
    img/ \
    -x "*.DS_Store" "img/screenshot*" "img/rawErrorCodes.png" "img/emperor.jpg"

echo "Created ${OUTPUT}"
