{
    "manifest_version": 3,
    "name": "PrequelErrorCodes",
    "version": "2.4.0",
    "minimum_chrome_version": "109",

    "description": "Change HTTP Error Codes to Prequel Memes",
    "permissions": ["webRequest", "storage", "tabs"],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "icons": {
        "16": "img/icon16.png",
        "48": "img/icon48.png",
        "128": "img/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [{
        "css": ["styles.css"],
        "js": ["content.js"],
        "matches": ["http://*/*", "https://*/*"],
        "run_at": "document_end"
    }],
    "web_accessible_resources": [{
        "resources": [
            "img/error_308.png", "img/error_400.png", "img/error_403.png",
            "img/error_404.png", "img/error_417.png", "img/error_500.png",
            "img/error_503.png", "img/error_misc.png"
        ],
        "matches": ["http://*/*", "https://*/*"]
    }]
}
